# ─── Sentinel AI Environment Configuration ───
# Copy this file to .env.local and fill in values.

# ─── Database (PostgreSQL) ───
# For GCP Cloud Run, connect to Cloud SQL using a public/private IP or the Cloud SQL Auth Proxy.
# DATABASE_URL=postgresql://user:password@<CLOUD_SQL_IP>:5432/sentinel_ai

# ─── PQC Key Management ───
# 32-byte hex-encoded seed for ML-DSA-65 key generation.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, a random seed is generated per-process (signatures won't verify across restarts).
# SENTINEL_PQC_SEED=your_64_char_hex_string_here

# ─── Auth Secret ───
# Secret for signing authentication tokens. Must be at least 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Without this, a random secret is generated per-process (tokens invalidated on restart).
# AUTH_SECRET=your_strong_secret_here

# ─── AI Explainer ───
# Optional: Enables GPT-4 powered explanations. Falls back to template without this.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# ─── RPC Provider ───
# Ethereum RPC URL for live chain context and transaction tracing.
# Falls back to heuristic analysis without this.
# For best simulation results, use an RPC that supports debug_traceCall (Alchemy, QuickNode).
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Tenderly Simulation (Optional) ───
# Full EVM simulation via Tenderly API. Provides the most accurate pre-signing analysis.
# Free tier available at https://dashboard.tenderly.co/
# TENDERLY_ACCESS_KEY=your_tenderly_access_key
# TENDERLY_ACCOUNT=your_tenderly_account
# TENDERLY_PROJECT=your_tenderly_project

# ─── ZK Proof Verification (Optional) ───
# Path to a Groth16 verification key JSON file for real ZK proof verification.
# Required if you want the application to accept ZK proofs.
# Without this, ZK proof verification fails closed and proofs are rejected.
# ZK_VERIFICATION_KEY_PATH=./keys/verification_key.json

# ─── Redis (Optional) ───
# If REDIS_URL is set, caching will use Redis. Otherwise falls back to PostgreSQL/in-memory.
# REDIS_URL=redis://localhost:6379

# —— Metrics Access ——
# Optional shared secret for server-to-server access to /api/metrics.
# Browser dashboards can also use a wallet auth token instead.
# METRICS_READ_TOKEN=your_metrics_read_token

# ─── CORS ───
# Allowed origin for API requests. Defaults to * (all origins).
# CORS_ORIGIN=https://yourdomain.com

# ─── Logging ───
# Minimum log level: debug, info, warn, error. Defaults to "info" in production, "debug" in dev.
# LOG_LEVEL=info

# ─── Node Environment ───
NODE_ENV=development

# ─── GCP Deployment ───
# PORT is auto-injected by Google Cloud Run.
# Ensure your VPC handles outbound connections if using internal Cloud SQL.
